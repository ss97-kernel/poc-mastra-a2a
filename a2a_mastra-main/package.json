{
  "name": "a2a-mastra-demo",
  "version": "1.0.0",
  "description": "Mastra A2A demo with multiple agents using OpenAI",
  "private": true,
  "workspaces": [
    "agents/gateway",
    "agents/data-processor",
    "agents/summarizer",
    "agents/web-search"
  ],
  "scripts": {
    "test": "vitest run",
    "dev": "docker compose --env-file .env up",
    "build": "docker compose --env-file .env build",
    "stop": "docker compose --env-file .env down"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
