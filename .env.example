# Application Ports
FRONTEND_PORT=3000
GATEWAY_PORT=3001
DATA_PROCESSOR_PORT=3002
SUMMARIZER_PORT=3003
WEB_SEARCH_PORT=3004

# Model Configuration
MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-replace-with-openai-key
OPENAI_MODEL=gpt-4.1-mini

# OpenBox
OPENBOX_URL=
OPENBOX_DEBUG=false
OPENBOX_GOVERNANCE_POLICY=fail_open
OPENBOX_SKIP_SIGNALS=resume
OPENBOX_APPROVAL_RESUME_POLL_INTERVAL_MS=5000
OPENBOX_VALIDATE=true
MASTRA_STORAGE_DIR=.mastra

# One OpenBox API key per runtime
OPENBOX_GATEWAY_API_KEY=obx_test_replace_gateway_key
OPENBOX_DATA_PROCESSOR_API_KEY=obx_test_replace_data_processor_key
OPENBOX_SUMMARIZER_API_KEY=obx_test_replace_summarizer_key
OPENBOX_WEB_SEARCH_API_KEY=obx_test_replace_web_search_key

# Langfuse (optional)
# Leave these blank if you do not want tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Web Search
# Required for web-search, news-search, and deep-research flows.
BRAVE_SEARCH_API_KEY=

# Runtime
NODE_ENV=development

# Optional: increase request body size for larger research workflows.
A2A_JSON_BODY_LIMIT=2mb
